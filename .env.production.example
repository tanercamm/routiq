# ── Domain Configuration ──
DOMAIN=routsky.com
API_DOMAIN=api.routsky.com
CERTBOT_EMAIL=admin@routsky.com

# ── Database ──
POSTGRES_PASSWORD=<generate-strong-password>

# ── API Keys (treat as secrets — never commit real values) ──
GEMINI_API_KEY=<your-gemini-api-key>
JWT_KEY=<generate-256-bit-key>
TRAVELBUDDY_RAPIDAPI_KEY=<your-rapidapi-key>
TURKISH_AIRLINES_PROXY_URL=<your-pipedream-webhook-url>

# ── OAuth Social Login (Optional) ──
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>

# ── Runtime ──
ASPNETCORE_ENVIRONMENT=Production
